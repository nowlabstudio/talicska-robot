# RPLidar A2M12 — CP2102 USB-UART Bridge
# Serial: 966e1891ce961f43afdbd8401f355cb7
# Persistent symlink: /dev/rplidar
# Függetlenül a csatlakozási sorrendtől, mindig /dev/rplidar lesz elérhető.
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", \
  ATTRS{serial}=="966e1891ce961f43afdbd8401f355cb7", \
  SYMLINK+="rplidar", MODE:="0666", GROUP:="dialout"
