# Network
JETSON_IP=10.0.10.1
MICROROS_AGENT_PORT=8888

# RoboClaw
ROBOCLAW_HOST=10.0.10.24
ROBOCLAW_PORT=8234

# Bridges
RC_BRIDGE_IP=10.0.10.22
INPUT_BRIDGE_IP=10.0.10.23
TILT_BRIDGE_IP=10.0.10.24

# Tailscale VPN — távoli elérés (subnet router mód, 10.0.10.0/24 hirdetve)
# A Jetson Tailscale IP-je: 100.71.242.128 (hostname: synapse)
# Részletek: docs/network_setup.md → "Tailscale VPN" szekció
TAILSCALE_IP=100.71.242.128

# Opcionális / jövőbeli hardware (placeholder — ha üres, a pre-start check kihagyja)
# Mikrotik LTE router: a robot külső hálózati kapcsolatának átjárója
MIKROTIK_IP=
# RTK-GPS: NTRIP caster vagy serial eszköz IP (TCP elérhetőség ellenőrzése)
RTK_GPS_IP=
# RTK-GPS serial port (ha nem TCP, hanem USB serial — pl. /dev/ttyACM0)
RTK_GPS_DEV=

# Stack selector
# USE_NAV=false  → hardware + teleop + safety only (teszteléshez, Nav2 nélkül)
# USE_NAV=true   → teljes stack (sensors + SLAM/Nav2 is elindul)
USE_NAV=true

# Safety limits — docker compose up -d után életbe lép (rebuild NEM kell)
# proximity: 0.0 = kikapcsolva (teszteléshez), 0.3 = normál üzem
PROXIMITY_DISTANCE_M=0.0
# estop: watchdog timeout másodpercben
ESTOP_TIMEOUT_S=2.0
# tilt: dőlésszög limitek fokban
# FONTOS: A safety_supervisor ÉS a startup_supervisor is használja!
#   - safety_supervisor: futásidőben folyamatosan ellenőrzi → ha túllépi, MEGÁLLÍTJA a robotot
#   - startup_supervisor: induláskor egyszer ellenőrzi → ha túllépi, FAULT (nem ARMED)
# 90° = kikapcsolva (kamera frame nem egyezik robot frame-mel, backlogban)
# Éles robot: 25.0 / 20.0 — csak a kamera→base_link transzformáció fix után!
TILT_ROLL_LIMIT_DEG=90.0
TILT_PITCH_LIMIT_DEG=90.0

# Startup check togglek — false = kihagyja a checkot, azonnal továbblép
# Deszkamodellen / fejlesztés közben kikapcsolható, ha a hardware még nem teljes
# FIGYELEM: false = fejlesztői mód — éles roboton ne hagyd így!
CHECK_MOTION_ENABLED=true
CHECK_TILT_ENABLED=false
CHECK_ESTOP_ENABLED=true
# Startup check timeoutok — RealSense lassan indul (~20-30s), elegendő mozgástér kell
TILT_TIMEOUT_S=30.0

# ROS2
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
CYCLONEDDS_URI=file:///root/talicska-robot/cyclonedds.xml
