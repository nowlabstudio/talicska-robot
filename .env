# =============================================================================
# .env — Talicska robot hardveres és hálózati konfiguráció
# =============================================================================
#
# ALAPELV: Csak hardverspecifikus értékek és egyetlen üzemeltetési kapcsoló.
# Biztonsági és viselkedési paraméterek → config/robot_params.yaml
# Profil-specifikus értékek → robot_params.yaml _profiles_ szekció
#
# Módosítás után: docker compose up -d (Compose újraolvassa az .env-t)
# =============================================================================

# ── Üzemeltetési mód ─────────────────────────────────────────────────────────
# FOLLOW:     személykövetés — ZED 2i aktív (make camera-fwd-up), 0.5 m/s
# SHUTTLE:    szállítás közbeni autonóm navigáció — ZED 2i aktív, 0.8 m/s
# REAR_NAV:   hátsó kamerás navigáció / dokkolás — RealSense aktív (make camera-rear-up), 0.1 m/s
# NAVIGATION: tesztelési mód — ZED + RealSense mindkettő aktív, 0.5 m/s
#
# camera_director_node: minden módban irány szerint vált (cmd_vel_raw figyelés)
#   előremenet → ZED aktív | hátramese → RealSense aktív
ROBOT_MODE=NAVIGATION

# Stack selector
# USE_NAV=false  → hardware + teleop + safety only (teszteléshez, Nav2 nélkül)
# USE_NAV=true   → teljes stack (sensors + SLAM/Nav2 is elindul)
USE_NAV=true

# ── Hálózat ──────────────────────────────────────────────────────────────────
JETSON_IP=10.0.10.1
MICROROS_AGENT_PORT=8888

# ── RoboClaw / USR-K6 serial bridge ──────────────────────────────────────────
# Az USR-K6 10.0.10.24 IP-n várja a TCP kapcsolatot 8234-es porton.
# A serial baud rate (460800) az USR-K6 web UI-ban van beállítva — NEM változtatni!
ROBOCLAW_HOST=10.0.10.24
ROBOCLAW_PORT=8234

# ── MicroROS bridge-ek (RP2040 + W6100) ──────────────────────────────────────
# Minden bridge UDP-n küldi az adatokat a MicroROS Agent-nek (JETSON_IP:MICROROS_AGENT_PORT)
RC_BRIDGE_IP=10.0.10.22       # /robot/motor_left, motor_right, rc_mode
INPUT_BRIDGE_IP=10.0.10.23    # /robot/estop  (E-Stop bridge — "INPUT" név legacy)
PEDAL_BRIDGE_IP=10.0.10.21    # /robot/pedal  (jövőbeli)

# ── Tailscale VPN ─────────────────────────────────────────────────────────────
# Jetson Tailscale IP (állandó, subnet router: 10.0.10.0/24)
# Részletek: docs/network_setup.md → "Tailscale VPN" szekció
TAILSCALE_IP=100.71.242.128

# ── Opcionális / jövőbeli hardware ───────────────────────────────────────────
# Ha üres, a pre-start check kihagyja az adott eszköz ellenőrzését
MIKROTIK_IP=
RTK_GPS_IP=
RTK_GPS_DEV=

# ── ROS2 DDS ──────────────────────────────────────────────────────────────────
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
CYCLONEDDS_URI=file:///root/talicska-robot/cyclonedds.xml
