<?xml version="1.0" encoding="UTF-8" ?>
<!--
  CycloneDDS configuration for Talicska robot (Jetson Orin Nano)

  Architektúra: minden container network_mode:host → DDS intra-host.
  Foxglove Studio WebSocket-en (TCP) csatlakozik, nem DDS-en.

  Interfészek:
    lo       (multicast=false): gyors intra-host adat path konténerek között
    enP8p1s0 (multicast=default, 192.168.68.x): DDS discovery multicast;
             FastDDS (microros_agent, rmw_fastrtps_cpp) ezen találja a
             CycloneDDS nodokat. Statikus fallback IP kell ha DHCP nem fut
             (enP8p1s0 NO-CARRIER esetén): 192.168.68.200/24 via NetworkManager.

  KIZÁRT interfészek (és miért):
    enP1p1s0 (10.0.10.x): RP2040 bridge-ek hálózata — DDS multicast elárasztaná
             → RC/E-stop/MicroROS UDP timeout. SOHA ne kerüljön DDS-be.
    WiFi (wlx*): DTIM buffering + basic-rate multicast → 10s+ latencia
    tailscale0: VPN overhead

  Foxglove Studio WebSocket TCP-n csatlakozik (nem DDS-en) → enP8p1s0 Foxglove
  cross-host DDS-hez kell (microros_agent discovery), Foxglove maga WebSocket.

  - MaxMessageSize: 65500B — RPLidar A2 scan message elfér egy UDP datagramban.
  - Discovery: ParticipantIndex auto, max 32.

  Network layout:
    Jetson enP1p1s0: 10.0.10.1/24  — robot internal (RP2040s) — DDS-ből KIZÁRVA
    Jetson enP8p1s0: 192.168.68.x  — lab LAN (Foxglove laptop, dev) — DDS discovery
    lo:              127.0.0.1      — intra-host adat path

  Usage:
    export CYCLONEDDS_URI=file:///path/to/cyclonedds.xml
    (docker-compose .env-ből kerül beállításra)
-->
<CycloneDDS>
  <Domain>
    <General>
      <!-- lo + wlx (AllowMulticast=false, unicast only):
           - lo: intra-host adat path konténerek között (gyors, nincs overhead)
           - wlx (multicast=false): CycloneDDS interfészként regisztrálva, de
             multicast=false + AllowMulticast=false → nincs WiFi DTIM buffering,
             nincs multicast flood; unicast discovery/adat loopbacken.
           - AllowMulticast=false: minden DDS forgalom unicast → nincs WiFi DTIM
             (5-6s késés) amit multicast data okozna WiFi AP DTIM buffering miatt.
           - Explicit peer 127.0.0.1: CycloneDDS SPDP-t küld 127.0.0.1:7400-ra →
             default FastDDS (microros_agent) bound to 0.0.0.0:7400 megkapja →
             cross-RMW discovery fastdds_loopback.xml nélkül is működik.

           enP8p1s0 KIZÁRVA: NO-CARRIER esetén dead endpoint (192.168.68.200) →
             FastDDS retry 5-6s timeout minden DDS kommunikációban.
           enP1p1s0 KIZÁRVA: RP2040 hálózat — DDS multicast elárasztaná.
           tailscale0 KIZÁRVA: VPN overhead.
           Foxglove WebSocket TCP-n csatlakozik (nem DDS) → interfész konfigtól
           független, de wlx-en keresztül elérhető marad. -->
      <Interfaces>
        <NetworkInterface name="lo"              priority="default" multicast="false"/>
        <NetworkInterface name="wlan0"           priority="default" multicast="false"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>

    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <!-- 64: a stack ~33 participant-ot futtat (rplidar, slam_toolbox, ekf,
           ros2_control, twist_mux, behavior_server, planner_server, controller_server,
           waypoint_follower, velocity_smoother, safety_supervisor, startup_supervisor,
           foxglove_bridge, microros_agent FastDDS×3, realsense2_camera,
           robot_state_publisher, rc_teleop, winch_node, bno08x_driver, ros2cli temp).
           A 32-es default elérve volt → "Failed to find a free participant index"
           hiba új processek indításakor. 64 ad fejlesztési + fault-recovery margint. -->
      <MaxAutoParticipantIndex>64</MaxAutoParticipantIndex>
      <!-- Explicit unicast peer: FastDDS (microros_agent) lo-only konfig esetén
           multicast nélkül is megtalálják egymást a résztvevők. -->
      <Peers>
        <Peer address="127.0.0.1"/>
      </Peers>
    </Discovery>

    <Tracing>
      <!-- Set to "warning" or "info" for debugging; "none" for production -->
      <Verbosity>warning</Verbosity>
      <OutputFile>/tmp/cyclonedds.log</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
