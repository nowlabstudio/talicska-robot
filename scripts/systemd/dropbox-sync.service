[Unit]
Description=Dropbox rclone mount
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
KillMode=process
RemainAfterExit=yes
ExecStartPre=-/usr/bin/fusermount -uz /home/eduard/Dropbox
ExecStart=/bin/bash /home/eduard/dropbox_sync.sh
ExecStop=-/usr/bin/fusermount -uz /home/eduard/Dropbox
Restart=on-failure
RestartSec=30s

[Install]
WantedBy=default.target
