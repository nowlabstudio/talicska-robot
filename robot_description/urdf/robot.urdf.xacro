<?xml version="1.0"?>
<!--
  Talicska rover — robot_description
  Physical measurements (2026-03-16, verified):
    Vehicle:        1100 mm long, 800 mm wide (wheel edge to edge), 750 mm tall
    Chassis:        640 × 550 × 140 mm, bottom at 120 mm, top at 260 mm
    Wheels:         Ø380 mm (r=190mm), 100 mm wide, 700 mm track (centre-centre)
    Axles:          front 340 mm from vehicle front, rear 790 mm → ±225 mm from base_link
    base_link:      rotation centre (axle midpoint), 565 mm from vehicle front, at ground (z=0)
    Chassis front:  240 mm behind vehicle front → +325 mm from base_link
    Platform:       1100 × 750 × 300 mm, bottom at 450 mm, tilts forward
    Tilt hinge:     chassis top (260 mm), 20 mm from chassis front → +305 mm from base_link
    LiDAR:          on chassis, 340 mm from chassis front → -15 mm from base_link, Z=295 mm
    Camera:         chassis front edge, Z=290 mm (lens centre 30 mm above chassis top)

  Wheel naming convention:
    rear_left / rear_right   — driven by RoboClaw (ros2_control joints)
    front_left / front_right — mechanically linked to rear, continuous joints
                               for correct TF visualisation

  diff_drive_controller must be configured with:
    left_wheel_names:  [rear_left_wheel_joint]
    right_wheel_names: [rear_right_wheel_joint]
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="talicska">

  <!-- ============================================================
       RoboClaw hardware arguments
       Override at launch: xacro robot.urdf.xacro tcp_host:=192.168.68.60
       ============================================================ -->
  <xacro:arg name="tcp_host"                  default="192.168.68.60"/>
  <xacro:arg name="tcp_port"                  default="8234"/>
  <xacro:arg name="socket_timeout"            default="0.05"/>
  <xacro:arg name="address"                   default="0x80"/>
  <!-- Combined encoder+gearbox counts per wheel revolution.
       Derived from Motion Studio QPPS (~230k) and ~14 km/h max speed.
       gear_ratio=1.0 because the individual CPR and mechanical ratio are unknown;
       this value represents total counts per wheel revolution.
       TODO: calibrate on wheels — see backlog. -->
  <xacro:arg name="encoder_counts_per_rev"    default="70300"/>
  <xacro:arg name="gear_ratio"                default="1.0"/>
  <xacro:arg name="motion_strategy"           default="speed_accel"/>
  <xacro:arg name="duty_accel_rate"           default="50000"/>
  <xacro:arg name="duty_decel_rate"           default="50000"/>
  <xacro:arg name="default_acceleration"      default="15000"/>
  <xacro:arg name="duty_max_rad_s"            default="20.5"/>
  <xacro:arg name="buffer_depth"              default="4"/>
  <xacro:arg name="auto_home_on_startup"      default="false"/>
  <xacro:arg name="position_limits_enabled"   default="false"/>
  <xacro:arg name="encoder_stuck_limit"       default="50"/>
  <xacro:arg name="encoder_runaway_limit"     default="5"/>
  <xacro:arg name="encoder_comm_fail_limit"   default="10"/>
  <xacro:arg name="encoder_max_speed_rad_s"   default="30.0"/>
  <!-- QPPS: Motion Studio mért encoder counts/sec a mechanikai maximumon.
       SetM1PID/SetM2PID PID referencia sebesség. Újrakalibráláskor frissítendő.
       NE számold ki encoder_counts_per_rev * encoder_max_speed_rad_s / 2π-ből
       (az ~336k lenne, mért érték ~230k — motorkarakter és slip eltérés miatt). -->
  <xacro:arg name="qpps"                     default="230000"/>
  <xacro:arg name="invert_left_motor"        default="true"/>
  <xacro:arg name="invert_right_motor"       default="true"/>

  <!-- ============================================================
       MESH BASE URL
       Foxglove needs HTTP access to meshes (package:// doesn't work in browser).
       Override at launch: xacro robot.urdf.xacro mesh_base:=package://robot_description
       Alternatives:
         LAN:       http://192.168.68.122:8081/robot_description
         Tailscale: http://100.71.242.128:8081/robot_description
         Robot net: http://10.0.10.1:8081/robot_description
       ============================================================ -->
  <xacro:arg name="mesh_base" default="http://192.168.68.122:8081/robot_description"/>
  <xacro:property name="mesh_base" value="$(arg mesh_base)"/>

  <!-- ============================================================
       GEOMETRY CONSTANTS  (metres)
       ============================================================ -->
  <!-- Chassis (alváz) -->
  <xacro:property name="chassis_length"    value="0.64"/>
  <xacro:property name="chassis_width"     value="0.55"/>
  <xacro:property name="chassis_height"    value="0.14"/>
  <xacro:property name="chassis_bottom_z"  value="0.12"/>
  <!-- Chassis centre in base_link frame:
       chassis front = +0.325, rear = -0.315, centre = +0.005 -->
  <xacro:property name="chassis_x_offset"  value="0.005"/>
  <xacro:property name="chassis_z_centre"  value="${chassis_bottom_z + chassis_height / 2.0}"/> <!-- 0.19 m -->

  <!-- Wheels -->
  <xacro:property name="wheel_radius"      value="0.19"/>
  <xacro:property name="wheel_width"       value="0.1"/>
  <xacro:property name="wheel_separation"  value="0.7"/>
  <xacro:property name="axle_offset"       value="0.225"/>

  <!-- Tilt platform (felépítmény) -->
  <xacro:property name="platform_length"   value="1.1"/>
  <xacro:property name="platform_width"    value="0.75"/>
  <xacro:property name="platform_height"   value="0.3"/>
  <!-- Hinge at chassis top, 20 mm from chassis front
       chassis front = +0.325 → hinge_x = +0.305
       Platform bottom at 450 mm, hinge at 260 mm → support rod height = 190 mm
       Platform centre Z relative to hinge: 190 + 150 = 340 mm
       Platform centre X relative to hinge: vehicle centre (0.0) is at -0.305 from hinge
       Platform spans +0.535 to -0.565 from base_link → centre = -0.015
       Relative to hinge: -0.015 - 0.305 = -0.320 -->
  <xacro:property name="hinge_x"           value="0.305"/>
  <xacro:property name="hinge_z"           value="0.26"/>
  <xacro:property name="platform_cg_x"     value="-0.32"/>
  <xacro:property name="platform_cg_z"     value="0.34"/>

  <!-- Mass distribution  (total ≈ 108 kg) -->
  <xacro:property name="chassis_mass"      value="84.0"/>
  <xacro:property name="wheel_mass"        value="6.0"/>
  <xacro:property name="platform_mass"     value="8.0"/>

  <!-- ============================================================
       INERTIA HELPERS
       ============================================================ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (y*y + z*z) / 12.0}"
        iyy="${m * (x*x + z*z) / 12.0}"
        izz="${m * (x*x + y*y) / 12.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (3*r*r + h*h) / 12.0}"
        iyy="${m * (3*r*r + h*h) / 12.0}"
        izz="${m * r*r / 2.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       WHEEL MACRO
       Joint frame: x=forward, y=left, z=up (ROS convention).
       Spin axis = Y (lateral) → axis xyz="0 1 0".
       Mesh origin = hub/axle mount point. Left wheels use mesh as-is,
       right wheels mirror on Y axis (scale 1 -1 1).
       ============================================================ -->
  <xacro:macro name="wheel" params="name x y reflect">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
        <geometry>
          <mesh filename="${mesh_base}/meshes/wheel.stl" scale="1 ${reflect} 1"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <axis   xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ============================================================
       BASE LINK  (rotation centre, at ground plane z=0)
       ============================================================ -->
  <link name="base_link">
    <visual>
      <!-- STL origin aligned to model nullpoint; lift to chassis_z_centre (0.19m) -->
      <origin xyz="0 0 ${chassis_z_centre}" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_base}/meshes/chassis.stl"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="${chassis_x_offset} 0 ${chassis_z_centre}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}"
      x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <!-- ============================================================
       WHEELS
       ============================================================ -->
  <!-- Rear — driven by RoboClaw via ros2_control -->
  <xacro:wheel name="rear_left_wheel"   x="${-axle_offset}" y="${ wheel_separation / 2.0}" reflect="1"/>
  <xacro:wheel name="rear_right_wheel"  x="${-axle_offset}" y="${-wheel_separation / 2.0}" reflect="-1"/>
  <!-- Front — mechanically linked to rear (same chain/shaft per side).
       Mimic joints: robot_state_publisher mirrors rear wheel joint states
       to front wheels automatically. No separate joint_state needed. -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
      <geometry>
        <mesh filename="${mesh_base}/meshes/wheel.stl" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="front_left_wheel"/>
    <origin xyz="${axle_offset} ${wheel_separation / 2.0} ${wheel_radius}" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <mimic  joint="rear_left_wheel_joint" multiplier="1.0" offset="0.0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
      <geometry>
        <mesh filename="${mesh_base}/meshes/wheel.stl" scale="1 -1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="front_right_wheel"/>
    <origin xyz="${axle_offset} ${-wheel_separation / 2.0} ${wheel_radius}" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <mimic  joint="rear_right_wheel_joint" multiplier="1.0" offset="0.0"/>
  </joint>

  <!-- ============================================================
       LIDAR — RPLidar A2
       On chassis, 340 mm from chassis front → X = -0.015 m from base_link
       Z = chassis top (0.26) + sensor half-height (0.035)
       ============================================================ -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="-0.015 0 0.295" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       CAMERA — RealSense D435i (rear-facing / docking)
       Chassis front edge (X = +0.325), lens centre 30 mm above chassis top
       Z = 0.26 + 0.03 = 0.29
       ============================================================ -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.325 0 0.29" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       ZED 2i — előre néző sztereó kamera (FOLLOW / SHUTTLE mód)
       Saját Docker containerben fut (zed-jetson/), topic-ok: /zed/zed_node/*
       Mérések (2026-04-06):
         z = 0.18 m (180 mm a robot base aljától — mért érték)
         y = 0.0   (hosszanti szimmetriatengelyen — mért érték)
         x = 0.480 m  *** PLACEHOLDER — mérés szükséges! ***
                      (könnyen frissíthető: volume-mounted, rebuild nem kell)
       ZED 2i fizikai méret: 175 × 33 × 30 mm
       IMU: csatlakoztatva, topic-ok elérhetők, TF letiltva (publish_imu_tf: false)
       ============================================================ -->
  <link name="zed_camera_link">
    <visual>
      <geometry><box size="0.175 0.033 0.030"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.175 0.033 0.030"/></geometry>
    </collision>
    <inertial>
      <mass value="0.165"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="zed_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="zed_camera_link"/>
    <!-- z=0.18m (mért), y=0.0 (szimmetriatengelyen), x=0.480m (PLACEHOLDER — mérés kell) -->
    <origin xyz="0.480 0.0 0.18" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       IMU — BNO085 (GY-BM0085)
       Dedikált 9-DOF IMU, I2C (i2c-7, 0x4B).
       Pozíció: robot hossztengelyén középen, LiDAR magasságán (X=0, Y=0, Z=0.295).
         X=0: tengelyközép (base_link origó)
         Y=0: szimmetriatengelyen
         Z=0.295: LiDAR magassága (lidar_joint Z)
       TODO: rpy — az IMU chip X/Y/Z tengelyeinek base_link-hez képesti forgatása.
             Helytelen rpy → EKF hibás orientáció-korrekció.
       ============================================================ -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.02 0.02 0.005"/></geometry>
    </visual>
    <inertial>
      <mass value="0.003"/>
      <inertia ixx="0.0000001" iyy="0.0000001" izz="0.0000001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <!-- xyz mérve (2026-03-26). rpy TODO: mérés után frissítendő! -->
    <origin xyz="0.0 0.0 0.295" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       TILT PLATFORM (felépítmény)
       Hinge at chassis top (Z=0.26), 20 mm from chassis front (X=+0.305).
       Platform 1100×750×300 mm, bottom at 450 mm when level.
       Support rods lift platform 190 mm above hinge.
       Platform centre relative to hinge: X=-0.32, Z=+0.34
       Tilts forward (positive Y rotation = nose down), max 45°.
       ============================================================ -->
  <link name="tilt_platform_link">
    <visual>
      <geometry>
        <mesh filename="${mesh_base}/meshes/platform.stl"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="${platform_cg_x} 0 ${platform_cg_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${platform_length} ${platform_width} ${platform_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${platform_mass}"
      x="${platform_length}" y="${platform_width}" z="${platform_height}"/>
  </link>
  <joint name="tilt_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="tilt_platform_link"/>
    <origin xyz="${hinge_x} 0 ${hinge_z}" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="0.0" upper="${pi/4}" effort="500.0" velocity="0.5"/>
  </joint>

  <!-- ============================================================
       ROS2_CONTROL — RoboClaw hardware interface
       Only rear wheels are controlled; front wheels are mechanically
       linked and not exposed to the controller.
       ============================================================ -->
  <ros2_control name="RoboClawSystem" type="system">
    <hardware>
      <plugin>roboclaw_hardware/RoboClawHardware</plugin>

      <param name="tcp_host">$(arg tcp_host)</param>
      <param name="tcp_port">$(arg tcp_port)</param>
      <param name="socket_timeout">$(arg socket_timeout)</param>
      <param name="address">$(arg address)</param>

      <param name="wheel_radius">${wheel_radius}</param>
      <param name="wheel_separation">${wheel_separation}</param>
      <param name="encoder_counts_per_rev">$(arg encoder_counts_per_rev)</param>
      <param name="gear_ratio">$(arg gear_ratio)</param>

      <param name="motion_strategy">$(arg motion_strategy)</param>
      <param name="default_acceleration">$(arg default_acceleration)</param>
      <param name="duty_accel_rate">$(arg duty_accel_rate)</param>
      <param name="duty_decel_rate">$(arg duty_decel_rate)</param>
      <param name="duty_max_rad_s">$(arg duty_max_rad_s)</param>
      <param name="buffer_depth">$(arg buffer_depth)</param>

      <param name="auto_home_on_startup">$(arg auto_home_on_startup)</param>
      <param name="position_limits_enabled">$(arg position_limits_enabled)</param>

      <param name="encoder_stuck_limit">$(arg encoder_stuck_limit)</param>
      <param name="encoder_runaway_limit">$(arg encoder_runaway_limit)</param>
      <param name="encoder_comm_fail_limit">$(arg encoder_comm_fail_limit)</param>
      <param name="encoder_max_speed_rad_s">$(arg encoder_max_speed_rad_s)</param>
      <param name="qpps">$(arg qpps)</param>

      <param name="invert_left_motor">$(arg invert_left_motor)</param>
      <param name="invert_right_motor">$(arg invert_right_motor)</param>
    </hardware>

    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <gpio name="diagnostics">
      <state_interface name="main_battery_v"/>
      <state_interface name="temperature_c"/>
      <state_interface name="error_status"/>
      <state_interface name="current_left_a"/>
      <state_interface name="current_right_a"/>
      <state_interface name="encoder_health"/>
    </gpio>
  </ros2_control>

</robot>
