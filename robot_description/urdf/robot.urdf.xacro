<?xml version="1.0"?>
<!--
  Talicska rover — robot_description
  Physical measurements:
    Chassis:        1100 × 800 mm, ~350 mm tall
    Wheels:         Ø400 mm (r=0.2m), 150 mm wide, 800 mm track
    Axles:          ±235 mm from rotation centre (= base_link)
    base_link:      rotation centre, at ground plane (z=0)
    Tilt hinge:     300 mm from platform front → 205 mm forward of base_link

  Wheel naming convention:
    rear_left / rear_right   — driven by RoboClaw (ros2_control joints)
    front_left / front_right — mechanically linked to rear, continuous joints
                               for correct TF visualisation

  diff_drive_controller must be configured with:
    left_wheel_names:  [rear_left_wheel_joint]
    right_wheel_names: [rear_right_wheel_joint]
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="talicska">

  <!-- ============================================================
       RoboClaw hardware arguments
       Override at launch: xacro robot.urdf.xacro tcp_host:=192.168.68.60
       ============================================================ -->
  <xacro:arg name="tcp_host"                  default="192.168.68.60"/>
  <xacro:arg name="tcp_port"                  default="8234"/>
  <xacro:arg name="socket_timeout"            default="0.05"/>
  <xacro:arg name="address"                   default="0x80"/>
  <xacro:arg name="encoder_counts_per_rev"    default="1000"/>
  <xacro:arg name="gear_ratio"                default="16.0"/>
  <xacro:arg name="motion_strategy"           default="duty_accel"/>
  <xacro:arg name="duty_accel_rate"           default="50000"/>
  <xacro:arg name="duty_decel_rate"           default="50000"/>
  <xacro:arg name="default_acceleration"      default="15000"/>
  <xacro:arg name="duty_max_rad_s"            default="22.5"/>
  <xacro:arg name="buffer_depth"              default="4"/>
  <xacro:arg name="auto_home_on_startup"      default="false"/>
  <xacro:arg name="position_limits_enabled"   default="false"/>
  <xacro:arg name="encoder_stuck_limit"       default="0"/>
  <xacro:arg name="encoder_runaway_limit"     default="5"/>
  <xacro:arg name="encoder_comm_fail_limit"   default="10"/>
  <xacro:arg name="encoder_max_speed_rad_s"   default="30.0"/>

  <!-- ============================================================
       GEOMETRY CONSTANTS  (metres)
       ============================================================ -->
  <!-- Chassis -->
  <xacro:property name="chassis_length"    value="1.1"/>
  <xacro:property name="chassis_width"     value="0.8"/>
  <xacro:property name="chassis_height"    value="0.35"/>
  <!-- base_link is 505 mm from front, 595 mm from rear.
       Visual box origin is at the chassis geometric centre: -->
  <xacro:property name="chassis_x_offset"  value="${0.505 - chassis_length / 2.0}"/> <!-- -0.045 m -->

  <!-- Wheels -->
  <xacro:property name="wheel_radius"      value="0.2"/>
  <xacro:property name="wheel_width"       value="0.15"/>
  <xacro:property name="wheel_separation"  value="0.8"/>
  <!-- Axles are equidistant from rotation centre: 595-360 = 235 mm -->
  <xacro:property name="axle_offset"       value="0.235"/>

  <!-- Tilt platform -->
  <xacro:property name="platform_length"   value="1.03"/>
  <xacro:property name="platform_width"    value="0.75"/>
  <xacro:property name="platform_height"   value="0.04"/>
  <!-- Hinge is 300 mm from platform front.  Joint frame origin = hinge.
       Platform CG from hinge (child +X = forward):
         (0.3 - 0.73) / 2 = -0.215 m  (mostly behind hinge) -->
  <xacro:property name="hinge_x"           value="${0.505 - 0.3}"/>           <!-- 0.205 m -->
  <xacro:property name="platform_cg_x"     value="${0.3 - platform_length / 2.0}"/> <!-- -0.215 m -->

  <!-- Mass distribution  (total ≈ 108 kg) -->
  <xacro:property name="chassis_mass"      value="84.0"/>
  <xacro:property name="wheel_mass"        value="6.0"/>
  <xacro:property name="platform_mass"     value="8.0"/>

  <!-- ============================================================
       INERTIA HELPERS
       ============================================================ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (y*y + z*z) / 12.0}"
        iyy="${m * (x*x + z*z) / 12.0}"
        izz="${m * (x*x + y*y) / 12.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (3*r*r + h*h) / 12.0}"
        iyy="${m * (3*r*r + h*h) / 12.0}"
        izz="${m * r*r / 2.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       WHEEL MACRO
       rpy="${-pi/2} 0 0" rotates the cylinder so its geometric axis
       aligns with the robot Y axis (lateral), which is the correct
       spin axis for diff_drive_controller with axis xyz="0 0 1".
       ============================================================ -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${x} ${y} ${wheel_radius}" rpy="${-pi/2} 0 0"/>
      <axis   xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- ============================================================
       BASE LINK  (rotation centre, at ground plane)
       ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="${chassis_x_offset} 0 ${wheel_radius + chassis_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="${chassis_x_offset} 0 ${wheel_radius + chassis_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}"
      x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <!-- ============================================================
       WHEELS
       ============================================================ -->
  <!-- Rear — driven by RoboClaw via ros2_control -->
  <xacro:wheel name="rear_left_wheel"   x="${-axle_offset}" y="${ wheel_separation / 2.0}"/>
  <xacro:wheel name="rear_right_wheel"  x="${-axle_offset}" y="${-wheel_separation / 2.0}"/>
  <!-- Front — mechanically linked to rear (same chain/shaft per side) -->
  <xacro:wheel name="front_left_wheel"  x="${ axle_offset}" y="${ wheel_separation / 2.0}"/>
  <xacro:wheel name="front_right_wheel" x="${ axle_offset}" y="${-wheel_separation / 2.0}"/>

  <!-- ============================================================
       LIDAR — RPLidar A2
       Mounted on top of chassis, forward-centre.
       NOTE: exact XY position to be verified with physical measurements.
       ============================================================ -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <!-- Top of chassis (z = wheel_radius + chassis_height) + sensor half-height -->
    <origin xyz="0.3 0 ${wheel_radius + chassis_height + 0.035}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       CAMERA — RealSense D435i
       Mounted on front face of chassis, centre height.
       NOTE: exact position to be verified with physical measurements.
       ============================================================ -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.505 0 ${wheel_radius + chassis_height / 2.0}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       TILT PLATFORM
       Hinge 300 mm from platform front → hinge at x=0.205 m from base_link.
       Joint frame origin = hinge.  Child +X = forward.
       Platform CG is 215 mm behind the hinge.
       ============================================================ -->
  <link name="tilt_platform_link">
    <visual>
      <origin xyz="${platform_cg_x} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${platform_length} ${platform_width} ${platform_height}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="${platform_cg_x} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${platform_length} ${platform_width} ${platform_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${platform_mass}"
      x="${platform_length}" y="${platform_width}" z="${platform_height}"/>
  </link>
  <joint name="tilt_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="tilt_platform_link"/>
    <origin xyz="${hinge_x} 0 ${wheel_radius + chassis_height + platform_height / 2.0}"
            rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="${-pi/4}" upper="${pi/4}" effort="500.0" velocity="0.5"/>
  </joint>

  <!-- ============================================================
       ROS2_CONTROL — RoboClaw hardware interface
       Only rear wheels are controlled; front wheels are mechanically
       linked and not exposed to the controller.
       ============================================================ -->
  <ros2_control name="RoboClawSystem" type="system">
    <hardware>
      <plugin>roboclaw_hardware/RoboClawHardware</plugin>

      <param name="tcp_host">$(arg tcp_host)</param>
      <param name="tcp_port">$(arg tcp_port)</param>
      <param name="socket_timeout">$(arg socket_timeout)</param>
      <param name="address">$(arg address)</param>

      <param name="wheel_radius">${wheel_radius}</param>
      <param name="wheel_separation">${wheel_separation}</param>
      <param name="encoder_counts_per_rev">$(arg encoder_counts_per_rev)</param>
      <param name="gear_ratio">$(arg gear_ratio)</param>

      <param name="motion_strategy">$(arg motion_strategy)</param>
      <param name="default_acceleration">$(arg default_acceleration)</param>
      <param name="duty_accel_rate">$(arg duty_accel_rate)</param>
      <param name="duty_decel_rate">$(arg duty_decel_rate)</param>
      <param name="duty_max_rad_s">$(arg duty_max_rad_s)</param>
      <param name="buffer_depth">$(arg buffer_depth)</param>

      <param name="auto_home_on_startup">$(arg auto_home_on_startup)</param>
      <param name="position_limits_enabled">$(arg position_limits_enabled)</param>

      <param name="encoder_stuck_limit">$(arg encoder_stuck_limit)</param>
      <param name="encoder_runaway_limit">$(arg encoder_runaway_limit)</param>
      <param name="encoder_comm_fail_limit">$(arg encoder_comm_fail_limit)</param>
      <param name="encoder_max_speed_rad_s">$(arg encoder_max_speed_rad_s)</param>
    </hardware>

    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <gpio name="diagnostics">
      <state_interface name="main_battery_v"/>
      <state_interface name="temperature_c"/>
      <state_interface name="error_status"/>
      <state_interface name="current_left_a"/>
      <state_interface name="current_right_a"/>
      <state_interface name="encoder_health"/>
    </gpio>
  </ros2_control>

</robot>
